# ============ DATABASE ============
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_murojaat?schema=public

# ============ REDIS ============
REDIS_URL=redis://localhost:6379

# ============ JWT ============
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ============ AI (Google Gemini) ============
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ============ TELEGRAM ============
TELEGRAM_BOT_TOKEN=
# Bot -> API o'rtasidagi ichki maxfiy kalit
BOT_API_SECRET=change-me-bot-secret

# ============ API ============
API_PORT=3001
API_URL=http://localhost:3001
WEB_URL=http://localhost:3000
# Swagger docs himoyasi (production): SWAGGER_ENABLED=true bo'lsa ochiladi
SWAGGER_ENABLED=true

# ============ FILES ============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=20

# ============ S3 / MinIO (ixtiyoriy) ============
# To'ldirilsa fayllar S3-mos storagega yuklanadi (MinIO uchun forcePathStyle yoqilgan)
# docker compose --profile s3 up -d  -> lokal MinIO ko'tariladi (http://localhost:9001 konsol)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# ============ WEB (Next.js) ============
NEXT_PUBLIC_API_URL=http://localhost:3001
